rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Residents can only read their own document after signing in
    match /residents/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // writes go through Cloud Functions only
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
